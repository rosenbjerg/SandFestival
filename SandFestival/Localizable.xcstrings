{
  "sourceLanguage" : "en",
  "strings" : {
    "%@ — %@" : {
      "comment" : "A button that focuses on a project by showing its name and the current state of the session. The state is either \"starting\", \"idle\", \"working\", \"waiting for permission\", \"waiting for idle\", \"blocked by auto mode\", \"errored\", or \"stopped\". The argument is the string “status.starting”, the string “status.idle”, the string “status.working”, the string “status.waiting_permission”, the string “status.waiting_idle”, the string “status.blocked_auto_mode”, the string “status.errored” or the string “status.stopped”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ — %2$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A label with a number and a system icon. The number is the number of projects that need attention.",
      "isCommentAutoGenerated" : true
    },
